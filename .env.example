# LabBrain — environment contract. NAMES ONLY. Never commit real values.
# Copy to .env.local and fill. See docs/env-contract.md for where each comes from.

# --- App ---
APP_URL=
NODE_ENV=development

# --- Supabase (Frankfurt / EU) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Document parsing ---
LLAMAPARSE_API_KEY=

# --- Inference mode (S11 — air-gap deployment switch) ---
# Which backend every inference seam (parse / embed / answer) uses. Default (unset
# or "cloud") = OpenAI + cloud LlamaParse, the standard hosted deployment. Set to
# "airgap" for an on-prem lab that wants NO request to leave the host: all five
# AIRGAP_/OLLAMA_/LLAMAPARSE_BASE_URL vars below become required and the resolver
# FAILS CLOSED if any is missing (never silently falls back to cloud). A typo'd
# value also throws — there is no third mode. See docs/env-contract.md.
INFERENCE_MODE=
# Base URL of the local Ollama OpenAI-compatible endpoint (airgap only), e.g. the
# /v1 path of the on-host Ollama server. Reused by both the embed and answer seams.
OLLAMA_BASE_URL=
# Local embedding model served by Ollama (airgap only). MUST produce vectors of the
# same dimension as the pgvector column — declared in AIRGAP_EMBEDDING_DIM, which is
# validated to equal that column at startup.
AIRGAP_EMBEDDING_MODEL=
AIRGAP_EMBEDDING_DIM=
# Local chat/answer model served by Ollama (airgap only).
AIRGAP_ANSWER_MODEL=
# Self-hosted LlamaParse base URL. In cloud mode this is an OPTIONAL override of the
# hosted LlamaParse API; in airgap mode it is REQUIRED and points at the on-prem
# LlamaParse instance so document bytes never leave the host.
LLAMAPARSE_BASE_URL=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Where bank-transfer / invoice requests are delivered (founder/sales inbox).
INVOICE_REQUEST_TO=
# Demo video link shown in the welcome email (AC-4.4). Falls back to APP_URL/demo.
DEMO_VIDEO_URL=

# --- Payments (Stripe — founder override; see tech-stack-decision.md) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs — create the products in the Stripe dashboard, then paste the
# price_… ids here (plan × billing interval). See docs/env-contract.md.
STRIPE_PRICE_STARTER_MONTH=
STRIPE_PRICE_STARTER_YEAR=
STRIPE_PRICE_PRO_MONTH=
STRIPE_PRICE_PRO_YEAR=

# --- Payments (Tap — primary JOD/Gulf rail; router picks it for JOD/KWD/SAR) ---
# One Tap secret API key (the `sk_…` credential, live or test mode). Used BOTH to
# authenticate Tap API calls AND to verify the webhook hashstring (HMAC-SHA256).
# There is no separate webhook secret. See docs/env-contract.md.
TAP_SECRET_KEY=
# KWD/SAR price points are founder configuration (no FX guessing). JOD is derived
# from lib/pricing/plans. Set these only when selling in KWD/SAR; amountFor THROWS
# until the matching key exists. Major units (e.g. 49.000 KWD), decimals per ISO.
TAP_PRICE_STARTER_MONTH_KWD=
TAP_PRICE_STARTER_YEAR_KWD=
TAP_PRICE_PRO_MONTH_KWD=
TAP_PRICE_PRO_YEAR_KWD=
TAP_PRICE_STARTER_MONTH_SAR=
TAP_PRICE_STARTER_YEAR_SAR=
TAP_PRICE_PRO_MONTH_SAR=
TAP_PRICE_PRO_YEAR_SAR=

# --- 2FA / SMS (Unifonic — S7) ---
# Unifonic AppSid: the SMS app credential from the Unifonic console. Authenticates
# every POST to the SMS API. Server-only — never expose to the client.
UNIFONIC_API_KEY=
# Registered SenderID (alphanumeric sender name approved by Unifonic, e.g. LabBrain).
UNIFONIC_SENDER_ID=
# One server secret — HMAC key for BOTH the OTP code hash and the lb_mfa elevation
# cookie. Min 32 bytes of randomness (e.g. `openssl rand -base64 32`). Server-only.
MFA_COOKIE_SECRET=

# --- Founder super-admin panel (S8) ---
# Comma-separated email allowlist for the /founder cross-tenant panel (AC-8.1).
# This is the ENTIRE founder gate — there is no platform-admin DB role. An email
# here can pause/activate any lab and read cross-tenant usage, so keep it tight.
# Server-only (no NEXT_PUBLIC_ prefix). Match the address the founder signs in with.
PLATFORM_ADMIN_EMAILS=

# --- Audit export / PDF rendering (S9) ---
# Absolute path to the system Chromium binary that puppeteer-core drives to
# render the audit-log PDF (AC-9.4). Set in the Contabo Docker image where
# chromium is installed (e.g. /usr/bin/chromium). Unset in CI/local — the render
# seam is mocked there, so tests never need a browser. CHROMIUM_PATH is an
# accepted alias. Without it, GET /api/audit/export 500s with a clear message.
PUPPETEER_EXECUTABLE_PATH=

# --- KSA data migration target (S10 — PDPL residency move) ---
# The AWS me-central-1 Supabase project that a verified tenant is migrated INTO
# (AC-10.3/10.5). Unset everywhere EXCEPT a real founder-run migration: CI, local,
# and every route construct their deps without touching these (createKsaTarget is
# lazy), so the app boots fine without them. The service key is the me-central-1
# project's service_role secret — server-only, NO NEXT_PUBLIC_ prefix (it bypasses
# RLS on the target). Provision the KSA project before the first KSA paying lab;
# see docs/env-contract.md and architecture/tech-stack-decision.md (residency).
KSA_SUPABASE_URL=
KSA_SUPABASE_SERVICE_KEY=

# --- Observability ---
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
